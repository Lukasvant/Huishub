rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function memberDocument(householdId) {
      return /databases/$(database)/documents/households/$(householdId)/members/$(request.auth.uid);
    }

    function isMember(householdId) {
      return signedIn() && exists(memberDocument(householdId));
    }

    function role(householdId) {
      return get(memberDocument(householdId)).data.role;
    }

    function canEdit(householdId) {
      return isMember(householdId) &&
        (role(householdId) == 'admin' || role(householdId) == 'partner');
    }

    function isAdmin(householdId) {
      return isMember(householdId) && role(householdId) == 'admin';
    }

    function initialAdminMembership(householdId, memberId) {
      return signedIn() &&
        memberId == request.auth.uid &&
        !exists(/databases/$(database)/documents/households/$(householdId)) &&
        getAfter(/databases/$(database)/documents/households/$(householdId)).data.createdBy == request.auth.uid &&
        request.resource.data.userId == request.auth.uid &&
        request.resource.data.role == 'admin';
    }

    function invitedMembership(householdId, memberId) {
      let invite = get(/databases/$(database)/documents/households/$(householdId)/invites/$(request.resource.data.inviteId));
      return signedIn() &&
        memberId == request.auth.uid &&
        request.resource.data.userId == request.auth.uid &&
        request.auth.token.email == request.resource.data.email &&
        invite.data.email == request.auth.token.email &&
        invite.data.status == 'pending' &&
        invite.data.role == request.resource.data.role &&
        (request.resource.data.role == 'partner' || request.resource.data.role == 'viewer');
    }

    match /users/{userId} {
      allow read, create, update: if signedIn() && userId == request.auth.uid;
      allow delete: if false;
    }

    match /households/{householdId} {
      allow create: if signedIn() &&
        request.resource.data.createdBy == request.auth.uid;
      allow read: if isMember(householdId);
      allow update: if isAdmin(householdId) &&
        request.resource.data.createdBy == resource.data.createdBy;
      allow delete: if isAdmin(householdId);

      match /members/{memberId} {
        allow read: if isMember(householdId);
        allow create: if initialAdminMembership(householdId, memberId) ||
          invitedMembership(householdId, memberId);
        allow update, delete: if isAdmin(householdId) &&
          resource.data.userId != request.auth.uid;
      }

      match /invites/{inviteId} {
        allow read: if isAdmin(householdId) ||
          (signedIn() && request.auth.token.email == resource.data.email);
        allow create, delete: if isAdmin(householdId);
        allow update: if isAdmin(householdId) ||
          (signedIn() &&
            resource.data.status == 'pending' &&
            resource.data.email == request.auth.token.email &&
            request.resource.data.email == resource.data.email &&
            request.resource.data.role == resource.data.role &&
            request.resource.data.createdBy == resource.data.createdBy &&
            request.resource.data.status == 'accepted' &&
            request.resource.data.acceptedBy == request.auth.uid);
      }

      match /tasks/{taskId} {
        allow read: if canEdit(householdId) ||
          (isMember(householdId) && resource.data.visibleToViewers == true);
        allow create: if canEdit(householdId) &&
          request.resource.data.householdId == householdId &&
          request.resource.data.createdBy == request.auth.uid;
        allow update: if canEdit(householdId) &&
          request.resource.data.householdId == resource.data.householdId &&
          request.resource.data.createdBy == resource.data.createdBy;
        allow delete: if canEdit(householdId);
      }

      match /groceryItems/{itemId} {
        allow read: if isMember(householdId);
        allow create: if canEdit(householdId) &&
          request.resource.data.householdId == householdId &&
          request.resource.data.addedBy == request.auth.uid;
        allow update: if canEdit(householdId) &&
          request.resource.data.householdId == resource.data.householdId &&
          request.resource.data.addedBy == resource.data.addedBy;
        allow delete: if canEdit(householdId);
      }

      match /agendaItems/{itemId} {
        allow read: if canEdit(householdId) ||
          (isMember(householdId) && resource.data.private == false);
        allow create: if canEdit(householdId) &&
          request.resource.data.householdId == householdId &&
          request.resource.data.createdBy == request.auth.uid &&
          request.resource.data.visibleToViewers == !request.resource.data.private;
        allow update: if canEdit(householdId) &&
          request.resource.data.householdId == resource.data.householdId &&
          request.resource.data.createdBy == resource.data.createdBy &&
          request.resource.data.visibleToViewers == !request.resource.data.private;
        allow delete: if canEdit(householdId);
      }

      match /notifications/{notificationId} {
        allow read: if canEdit(householdId) ||
          (isMember(householdId) && resource.data.recipientId == request.auth.uid);
        allow create, update, delete: if canEdit(householdId);
      }
    }

    // Enables tightly constrained collection-group queries during login.
    match /{path=**}/members/{memberId} {
      allow read: if signedIn() &&
        resource.data.userId == request.auth.uid;
    }

    match /{path=**}/invites/{inviteId} {
      allow read: if signedIn() &&
        request.auth.token.email == resource.data.email;
    }
  }
}
