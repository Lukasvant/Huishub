{
  "name": "taskhive",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "deploy": "npm run build && npx firebase-tools deploy --only firestore:rules,firestore:indexes,hosting",
    "deploy:functions": "npx firebase-tools deploy --only functions",
    "deploy:all": "npm run build && npx firebase-tools deploy --only firestore:rules,firestore:indexes,functions,hosting",
    "start": "next start",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:rules": "npx --yes firebase-tools@15.20.0 emulators:exec --only firestore --project taskhive-rules-test \"vitest run --config vitest.rules.config.ts\"",
    "test:watch": "vitest"
  },
  "dependencies": {
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "firebase": "^12.13.0",
    "lucide-react": "^0.511.0",
    "next": "^16.2.6",
    "react": "^19.2.6",
    "react-dom": "^19.2.6"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.1",
    "@firebase/rules-unit-testing": "^5.0.1",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^22.15.29",
    "@types/react": "^19.1.6",
    "@types/react-dom": "^19.1.5",
    "@vitejs/plugin-react": "^5.0.0",
    "autoprefixer": "^10.4.21",
    "eslint": "^9.28.0",
    "eslint-config-next": "^16.2.6",
    "jsdom": "^26.1.0",
    "postcss": "^8.5.4",
    "prettier": "^3.5.3",
    "tailwindcss": "^3.4.19",
    "typescript": "^5.8.3",
    "vitest": "^4.1.7"
  },
  "overrides": {
    "next": {
      "postcss": "$postcss"
    }
  }
}
